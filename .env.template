# =========================================================================
# Template de Configurações e Variáveis de Ambiente do Kaggle Express
# Copie este arquivo como '.env' e preencha as variáveis de acordo.
# O arquivo '.env' resultante contendo chaves reais NÃO será enviado ao Git.
# =========================================================================

# Nome padrão da competição para download automático de dados via CLI
COMPETITION_NAME=nome-da-competicao

# Credenciais da Kaggle API (Alternativa ao arquivo ~/.kaggle/kaggle.json)
KAGGLE_USERNAME=seu_usuario_kaggle
KAGGLE_KEY=sua_chave_secreta_api_kaggle

# Configurações do Weights & Biases (Opcional - para Tracking de Experimentos)
WANDB_API_KEY=sua_chave_secreta_api_wandb
WANDB_PROJECT=nome-do-seu-projeto-wandb

# Configurações do MLflow (Opcional)
MLFLOW_TRACKING_URI=http://localhost:5000

# Configurações da OpenAI API (Opcional - para uso com LangChain / LLMs)
OPENAI_API_KEY=sua_chave_secreta_openai

# Configurações do LangSmith (Opcional - Rastreabilidade de Agentes com LangGraph)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=sua_chave_secreta_langsmith
LANGCHAIN_PROJECT=seu-projeto-langsmith
